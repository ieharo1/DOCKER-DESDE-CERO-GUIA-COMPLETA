@model Examen.ViewModels.UsuarioCiudad

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>user</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="user.nombre" class="control-label"></label>
                <input asp-for="user.nombre" class="form-control" />
                <span asp-validation-for="user.nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="user.ci_ruc" class="control-label"></label>
                <input asp-for="user.ci_ruc" class="form-control" />
                <span asp-validation-for="user.ci_ruc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="user.id_ciudad" class="control-label"></label>
                <select asp-for="ciudadnombre" asp-items="Model.MustraCiudadesCreacion">
                </select>
                <span asp-validation-for="user.id_ciudad" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="user.arm" /> @Html.DisplayNameFor(model => model.user.arm)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="user.uci" /> @Html.DisplayNameFor(model => model.user.uci)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a class="btn border-info" asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
